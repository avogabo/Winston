<?xml version="1.0"?>
<Container version="2">
  <Name>Winston</Name>
  <Repository>ghcr.io/avogabo/winston:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/avogabo/Winston</Support>
  <Project>https://github.com/avogabo/Winston</Project>
  <Overview>Sequential NZB importer for AltMount with review UI and FileBot integration.</Overview>
  <Category>Downloaders:</Category>
  <WebUI>http://[IP]:[PORT:8091]</WebUI>
  <TemplateURL/>
  <Icon/>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Mount /config persistently, mount /data/nzb to your NZB folder, and copy license.psm to /config/filebot/license.psm once.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <ContainerPort>8091</ContainerPort>
        <HostPort>8091</HostPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/winston/config</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/NZB/winston-test</HostDir>
      <ContainerDir>/data/nzb</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Name>WINSTON_HTTP_LISTEN_ADDR</Name>
      <Value>:8091</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_SOURCE_ROOT</Name>
      <Value>/data/nzb</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_ALTMOUNT_BASE_URL</Name>
      <Value>http://192.168.1.100:8989</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_ALTMOUNT_API_KEY</Name>
      <Value>CHANGE_ME</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_DEFAULT_MODE</Name>
      <Value>filebot</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_SLEEP_BETWEEN_IMPORTS</Name>
      <Value>3s</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_AUTOIMPORT_MEDIUM</Name>
      <Value>true</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_FILEBOT_FORMAT_MOVIE</Name>
      <Value>Peliculas/{plex}</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_FILEBOT_FORMAT_SERIES</Name>
      <Value>Series/{plex}</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_FILEBOT_DB</Name>
      <Value>TheMovieDB</Value>
    </Variable>
    <Variable>
      <Name>WINSTON_FILEBOT_BINARY</Name>
      <Value>/usr/local/bin/filebot</Value>
    </Variable>
    <Variable>
      <Name>FILEBOT_HOME</Name>
      <Value>/config/filebot</Value>
    </Variable>
  </Environment>
</Container>
